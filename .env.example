# ── Site ─────────────────────────────────────────────
# Canonical site URL (no trailing slash); used for canonical/OG/sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Runtime mode ─────────────────────────────────────
# mock = Mock executor + skip OAuth (local dev) | real = full validation
APP_MODE=mock

# ── Database (Neon Postgres) ─────────────────────────
DATABASE_URL=

# ── Auth.js (GitHub OAuth) ───────────────────────────
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Cloudflare R2 (artifacts + prebuilt images) ──────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for prebuilt image downloads (R2 custom domain)
R2_PUBLIC_BASE_URL=

# ── Build executor (GitHub Actions, V1) ──────────────
# Fine-grained PAT with actions:write on the build repo
BUILD_GITHUB_TOKEN=
# owner/repo of the public build repository
BUILD_REPO=
# Secret for verifying workflow_run webhook callbacks
BUILD_WEBHOOK_SECRET=

# ── Analytics (production only; app loads GTM only) ──
NEXT_PUBLIC_GTM_ID=
